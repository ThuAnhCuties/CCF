{
  "name": "cloudflare-gateway-pihole-scripts",
  "version": "3.0.0",
  "type": "module",
  "description": "Automated Cloudflare Gateway list management with Pi-hole compatible blocklists",
  "keywords": [
    "cloudflare",
    "gateway",
    "pihole",
    "blocklist",
    "allowlist",
    "dns-filtering",
    "zero-trust"
  ],
  "license": "MIT",
  "author": "",
  "scripts": {
    "start": "npm run download && npm run cloudflare:create",
    "dev": "npm run download && cross-env DRY_RUN=1 npm run cloudflare:create:list",
    "dry": "npm run download && cross-env DRY_RUN=1 npm run cloudflare:create:list",
    "download": "node --experimental-strip-types --experimental-transform-types download_lists.js",
    "download:allowlist": "node --experimental-strip-types --experimental-transform-types download_lists.js allowlist",
    "download:blocklist": "node --experimental-strip-types --experimental-transform-types download_lists.js blocklist",
    "sync": "npm run download && npm run cloudflare:create",
    "sync:blocklist": "npm run download:blocklist && npm run cloudflare:create",
    "cloudflare:refresh": "npm run download && npm run cloudflare:create",
    "cloudflare:refresh:blocklist": "npm run download:blocklist && npm run cloudflare:create",
    "cloudflare:create": "npm run cloudflare:create:list && npm run cloudflare:create:rule",
    "cloudflare:delete": "npm run cloudflare:delete:rule && npm run cloudflare:delete:list",
    "cloudflare:create:rule": "node --experimental-strip-types cf_gateway_rule_create.js",
    "cloudflare:create:list": "node --experimental-strip-types cf_list_create.js",
    "cloudflare:delete:rule": "node --experimental-strip-types cf_gateway_rule_delete.js",
    "cloudflare:delete:list": "node --experimental-strip-types cf_list_delete.js",
    "cloudflare:defragment": "node --experimental-strip-types cf_defragment.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,json,md,yml,yaml}\"",
    "test": "node --test --experimental-test-coverage",
    "test:watch": "node --test --watch",
    "prepare": "node --eval \"console.log('✓ Ready for production')\""
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.2.0",
  "dependencies": {},
  "devDependencies": {
    "eslint": "^9.24.0",
    "prettier": "^3.6.0",
    "cross-env": "^7.0.3"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 100,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "es2026": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "prefer-const": "error",
      "no-var": "error",
      "eqeqeq": ["error", "always"]
    }
  },
  "node": {
    "experimental-strip-types": true,
    "experimental-transform-types": true,
    "experimental-test-coverage": true
  }
}
